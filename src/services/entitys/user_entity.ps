import regex


Entity PersonDefault() {
    action __init__(self, nome, idade, email, cpf, nick, senha) {
        self.nome = nome
        self.email = email
        self.nick = nick
        self.senha = Parsing.integer(senha, to int)
        self.idade = Parsing.integer(idade, to int)
        self.cpf = Parsing.integer(cpf, to int)
    }

    @NonNull
    action NAMEparser(self) {
        if (self.nome.isalpha() and len(self.nome) <= 60 and type(self.nome) == str) {
            return True
        } else {
            return False
        }
    }

    @NonNull @static
    action EMAILparser(self) {
        email_correto = regex.match(r"^[a-zA-Z0-9.!#$%&'*+/=?^_`{|}~-]+@[a-zA-Z0-9](?:[a-zA-Z0-9-]{0,61}[a-zA-Z0-9])?(?:\.[a-zA-Z0-9](?:[a-zA-Z0-9-]{0,61}[a-zA-Z0-9])?)*$", self.email)

        if (!email_correto) {
            return "Email invalido"
        }

        if (self.email.type() == str and len(self.email) <= 100 and self.email.islower()) {
            return True
        } else {
            return False
        }
    }

    @NonNull @static
    action AGEparser(self) {
        if (self.idade.type() == int and len(self.idade) <= 3) {
            return True
        } else {
            return False
        }
    }

    @NonNull @static
    action CPFparser(self) {
        if (self.cpf.type() == int and len(self.cpf) == 11) {
            return True
        } else {
            return False
        }
    }

    @NonNull @static
    action SENHAparser(self) {
        if (self.senha.type() == int and self.senha.len() <= 20) {
            return True
        } else {
            return False
        }
    }

    @NonNull @static
    action NICKparser(self) {
        if (self.nick.type() == str and self.nick.isalpha() and self.nome.islower() and len(self.nick) <= 20) {
            return True
        }
        return False
    }

}


// 10/06/2026: Validar o funcionamento do CGNVvalider, pois não foi testado.

Entity Admin():
    action __init__(self, nome, email, senha, cargo=null, nivel=null, data_user_db=null):
        self.cargo = cargo
        self.nivel = nivel
        self.nome = nome
        self.senha = Parsing.integer(senha, to int)
        self.email = email

    action typesCGNV(self, cargo_1=str, nivel_1=int):
        if cargo_1.type() != str and nivel_1.type() != int:
            return True
        else:
            return False

    action CGNVvalider(self):
        cg = self.data_user_db["cargo"]
        nv = self.data_user_db["nivel"]
        cargo = self.cargo
        nivel = self.nivel

        if !self.typesCGNV(cargo, nivel):
            return "Cargos e niveis com tipos errados: typesCGNV"

        if not count str(cargo) in cg and not count str(nivel) in nv:
            return False
        else:
            return True

    action NAMEvalider(self):
        if self.nome.type() == str and len(self.nome) <= 60 and self.nome.islower():
            return True
        else:
            return False

    action EMAILvalider(self):
        email_correto = regex.match(r"^[a-zA-Z0-9.!#$%&'*+/=?^_`{|}~-]+@[a-zA-Z0-9](?:[a-zA-Z0-9-]{0,61}[a-zA-Z0-9])?(?:\.[a-zA-Z0-9](?:[a-zA-Z0-9-]{0,61}[a-zA-Z0-9])?)*$", self.email)

        if (!email_correto) {
            return "Email invalido"
        }
        if self.email.islower() and len(self.email) <= 100:
            return True
        else:
            return False

    action SENHAvalider(self):
        if self.senha.type() == int and self.senha.len() <= 20:
            return True
        else:
            return False