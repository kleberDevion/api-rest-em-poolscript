import date

// services for use of the system
from services.service_ctrl_user import serviceUserLogin, serviceUserSingIn
from services.smtp_controll import allMailData, inboxMailData, sentMailData, cadastroClientAccountt

from jinker import Jinker, cors, jsonify, render

app = Jinker(__name__, oauth={poolip: true})
cors(options=["GET", "POST", "DELETE", "PATCH", "PUT"], origins=["https://nome.com"])


// root route
@app.route("/", methods=cors.options(["POST"]), auth=cors.origins()) {
    action homeSection() {
        post(<6A9955>f"[NewRequest]: Nova requisição em '/mail/inbox' | data [{<eee>date.today()}] | horario [{<eee>date.time()}]")
        data = request.json()
        if (data not is none) {
            return render("dist", "intro.jsx")
        }
        return "Error: 500"
    }
}

// login route
@app.route("/login", methods=cors.options(["POST"]), auth=cors.origins()) {
    action handlerLogin() {
        str data = request.get_json()
        post(<6A9955>f"[NewRequest]: Nova requisição em '/mail/inbox' | data [{<eee>date.today()}] | horario [{<eee>date.time()}]")
        if (not count str("nome") in data and not count str("senha") in data and not count str("email") in data) {
            return jsonify({
                "status": "400",
                "msg": "Yours data they are null, try send again"
            }), 400
        } else {
            return serviceUserLogin(data)
        }
        return 500
    }
}

