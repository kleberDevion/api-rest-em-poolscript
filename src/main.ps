// emails user
@app.route(f"/mail/inbox/<id>", methods=cors.options(["GET"]), auth=cors.origins()) {
    action handlerInboxMail() {
        user_id = request.path_param('id')
        post(<6A9955>f"[NewRequest]: Nova requisição em '/mail/inbox' | data [{<eee>date.today()}] | horario [{<eee>date.time()}]")
        if (user_id) {
            return inboxMailData(user_id)
        }
        return "Error: 500"
    }
}


